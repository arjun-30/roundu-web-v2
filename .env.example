# Firebase Web Config — get from Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=roundu-xxxxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=roundu-xxxxx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=roundu-xxxxx.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin portal password — pick a strong random password
# Access the admin at https://roundu.in/admin
NEXT_PUBLIC_ADMIN_PASSWORD="your-strong-password-here"
